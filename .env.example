# PostgreSQL superuser (used only for DB init)
POSTGRES_DB=hermes_db
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=change_me_superuser

# Newsletter Engine DB user (read/write)
NEWSLETTER_ENGINE_DB_USER=newsletter_engine
NEWSLETTER_ENGINE_DB_PASSWORD=change_me_newsletter

# Hermès DB user (read-only on business tables)
HERMES_DB_USER=hermes_readonly
HERMES_DB_PASSWORD=change_me_hermes

# LiteLLM DB — base séparée, aucun accès aux données métier de hermes_db
LITELLM_DB_NAME=litellm_db
LITELLM_DB_USER=litellm
LITELLM_DB_PASSWORD=change_me_litellm_db

# Anthropic API (centralisé dans LiteLLM — newsletter-engine et Hermes n'y accèdent pas directement)
ANTHROPIC_API_KEY=sk-ant-...

# LiteLLM — clé maître du proxy (admin uniquement, ne pas distribuer aux services)
LITELLM_MASTER_KEY=change_me_litellm_master_key

# LiteLLM virtual keys — générées une fois via scripts/litellm-init-keys.sh
# Hermes : accès restreint au modèle "hermes" uniquement
LITELLM_HERMES_KEY=
# Newsletter-engine : accès restreint au modèle "enrichment" uniquement
LITELLM_ENRICHMENT_KEY=

# Gmail OAuth (copy the Google OAuth JSON client to config/client_secret.json)
EMAIL_BACKEND=gmail
GMAIL_CLIENT_SECRET_PATH=/app/config/client_secret.json
GMAIL_TOKEN_PATH=/app/config/gmail_token.json
# Optional: change the temporary local OAuth callback port
GMAIL_AUTH_PORT=8888

# Local email backend for dev/test without Gmail
LOCAL_MAILBOX_DIR=/app/config/dev_mailbox
ENRICHMENT_BACKEND=anthropic

# Hermes Agent — clé d'authentification pour l'API server (port 8642)
HERMES_API_KEY=change_me_hermes_api_key
HERMES_WEBHOOK_SECRET=change_me_hermes_webhook_secret
